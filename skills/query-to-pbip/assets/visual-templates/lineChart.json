      {
        "name": "{{FilterGuidTopN}}",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "{{CategoryTable}}"
              }
            },
            "Property": "{{CategoryColumn}}"
          }
        },
        "type": "TopN",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "subquery",
              "Expression": {
                "Subquery": {
                  "Query": {
                    "Version": 2,
                    "From": [
                      {
                        "Name": "d1",
                        "Entity": "{{CategoryTable}}",
                        "Type": 0
                      },
                      {
                        "Name": "f",
                        "Entity": "{{MeasureTable}}",
                        "Type": 0
                      }
                    ],
                    "Select": [
                      {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "d1"
                            }
                          },
                          "Property": "{{CategoryColumn}}"
                        },
                        "Name": "field"
                      }
                    ],
                    "OrderBy": [
                      {
                        "Direction": "{{TopNDirection}}",
                        "Expression": {
                          "Measure": {
                            "Expression": {
                              "SourceRef": {
                                "Source": "f"
                              }
                            },
                            "Property": "{{MeasureName}}"
                          }
                        }
                      }
                    ],
                    "Top": "{{TopNValue}}"
                  }
                }
              },
              "Type": 2
            },
            {
              "Name": "d1",
              "Entity": "{{CategoryTable}}",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "In": {
                  "Expressions": [
                    {
                      "Column": {
                        "Expression": {
                          "SourceRef": {
                            "Source": "d1"
                          }
                        },
                        "Property": "{{CategoryColumn}}"
                      }
                    }
                  ],
                  "Table": {
                    "SourceRef": {
                      "Source": "subquery"
                    }
                  }
                }
              }
            }
          ]
        }
      },
      {
        "name": "{{DateRangeFilterGuid}}",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "{{DateRangeEntity}}"
              }
            },
            "Property": "{{DateRangeProperty}}"
          }
        },
        "type": "Advanced",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "{{DateRangeAlias}}",
              "Entity": "{{DateRangeEntity}}",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "And": {
                  "Left": {
                    "Comparison": {
                      "ComparisonKind": 2,
                      "Left": {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "{{DateRangeAlias}}"
                            }
                          },
                          "Property": "{{DateRangeProperty}}"
                        }
                      },
                      "Right": {
                        "DateSpan": {
                          "Expression": {
                            "Literal": {
                              "Value": "{{DateStart}}"
                            }
                          },
                          "TimeUnit": 5
                        }
                      }
                    }
                  },
                  "Right": {
                    "Comparison": {
                      "ComparisonKind": 4,
                      "Left": {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "{{DateRangeAlias}}"
                            }
                          },
                          "Property": "{{DateRangeProperty}}"
                        }
                      },
                      "Right": {
                        "DateSpan": {
                          "Expression": {
                            "Literal": {
                              "Value": "{{DateEnd}}"
                            }
                          },
                          "TimeUnit": 5
                        }
                      }
                    }
                  }
                }
              }
            }
