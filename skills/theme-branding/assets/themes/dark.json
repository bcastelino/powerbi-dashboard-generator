{
  "$schema": "https://raw.githubusercontent.com/microsoft/powerbi-desktop-samples/main/Report%20Theme%20JSON%20Schema/reportThemeSchema-2.140.json",
  "name": "Dark",
  "dataColors": [
    "#19F5E2",
    "#FF6F61",
    "#B07BAC",
    "#FFD166",
    "#06D6A0",
    "#118AB2",
    "#EF476F",
    "#073B4C"
  ],
  "good": "#06D6A0",
  "neutral": "#888888",
  "bad": "#EF476F",
  "maximum": "#19F5E2",
  "center": "#118AB2",
  "minimum": "#073B4C",
  "null": "#2A2A2A",
  "background": "#1E1E1E",
  "secondaryBackground": "#2A2A2A",
  "foreground": "#EEEEEE",
  "secondaryForeground": "#AAAAAA",
  "tableAccent": "#19F5E2",
  "textClasses": {
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 40,
      "color": "#19F5E2"
    },
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#19F5E2"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#EEEEEE"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#CCCCCC"
    },
    "lightLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 9,
      "color": "#AAAAAA"
    },
    "largeLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 12,
      "color": "#EEEEEE"
    },
    "smallLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 8,
      "color": "#AAAAAA"
    },
    "semiboldLabel": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 10,
      "color": "#EEEEEE"
    },
    "boldLabel": {
      "fontFace": "Segoe UI Bold",
      "fontSize": 10,
      "color": "#EEEEEE"
    },
    "largeLightLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 11,
      "color": "#AAAAAA"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#252525"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#3A3A3A"
              }
            },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#19F5E2"
              }
            },
            "fontSize": 14,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#1E1E1E"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#111111"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "labels": [
          {
            "fontSize": 32,
            "color": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 0,
                      "Percent": 0
                    }
                  }
                }
              }
            }
          }
        ],
        "categoryLabels": [
          {
            "fontSize": 11,
            "color": {
              "solid": {
                "color": "#AAAAAA"
              }
            }
          }
        ]
      },
      "Hero": {
        "labels": [
          {
            "fontSize": 48
          }
        ],
        "categoryLabels": [
          {
            "fontSize": 14
          }
        ]
      }
    }
  }
}