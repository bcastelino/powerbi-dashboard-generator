                  "Property": "{{SeriesColumn}}"
                }
              },
              "queryRef": "{{SeriesTable}}.{{SeriesColumn}}",
              "nativeQueryRef": "{{SeriesColumn}}"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
