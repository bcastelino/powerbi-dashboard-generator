{
  "$schema": "https://raw.githubusercontent.com/microsoft/powerbi-desktop-samples/main/Report%20Theme%20JSON%20Schema/reportThemeSchema-2.140.json",
  "name": "Modern",
  "dataColors": [
    "#19A0AA",
    "#F15A29",
    "#3D5A80",
    "#EE6C4D",
    "#293241",
    "#98C1D9",
    "#E0FBFC",
    "#B07BAC"
  ],
  "good": "#19A0AA",
  "neutral": "#98C1D9",
  "bad": "#F15A29",
  "maximum": "#19A0AA",
  "center": "#98C1D9",
  "minimum": "#E0FBFC",
  "null": "#EEEEEE",
  "background": "#F7F7F7",
  "secondaryBackground": "#FFFFFF",
  "foreground": "#222222",
  "secondaryForeground": "#5C6B73",
  "tableAccent": "#19A0AA",
  "textClasses": {
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 38,
      "color": "#19A0AA"
    },
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#19A0AA"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#222222"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#222222"
    },
    "lightLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 9,
      "color": "#5C6B73"
    },
    "largeLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 12,
      "color": "#222222"
    },
    "smallLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 8,
      "color": "#5C6B73"
    },
    "semiboldLabel": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 10,
      "color": "#222222"
    },
    "boldLabel": {
      "fontFace": "Segoe UI Bold",
      "fontSize": 10,
      "color": "#222222"
    },
    "largeLightLabel": {
      "fontFace": "Segoe UI",
      "fontSize": 11,
      "color": "#5C6B73"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E5E5"
              }
            },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#19A0AA"
              }
            },
            "fontSize": 14,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F7F7F7"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#EFEFEF"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "labels": [
          {
            "fontSize": 32,
            "color": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 0,
                      "Percent": 0
                    }
                  }
                }
              }
            }
          }
        ],
        "categoryLabels": [
          {
            "fontSize": 11,
            "color": {
              "solid": {
                "color": "#5C6B73"
              }
            }
          }
        ]
      },
      "Hero": {
        "labels": [
          {
            "fontSize": 48
          }
        ],
        "categoryLabels": [
          {
            "fontSize": 14
          }
        ]
      }
    }
  }
}