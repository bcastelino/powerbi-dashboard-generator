            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "{{MeasureTable2}}"
                    }
                  },
                  "Property": "{{MeasureName2}}"
                }
              },
              "queryRef": "{{MeasureTable2}}.{{MeasureName2}}",
              "nativeQueryRef": "{{MeasureName2}}"
            }
          ]
        },
        "Tooltips": {
          "projections": [
            {
              "field": {
                "Aggregation": {
                  "Expression": {
                    "Column": {
                      "Expression": {
                        "SourceRef": {
                          "Entity": "{{TooltipTable}}"
                        }
                      },
                      "Property": "{{TooltipColumn}}"
                    }
                  },
                  "Function": 0
                }
              },
              "queryRef": "Sum({{TooltipTable}}.{{TooltipColumn}})",
              "nativeQueryRef": "Sum of {{TooltipColumn}}"
