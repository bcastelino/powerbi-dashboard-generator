{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "{{VisualName}}",
  "position": {
    "x": 20,
    "y": 20,
    "z": 0,
    "height": 680,
    "width": 1240,
    "tabOrder": 0
  },
  "visual": {
    "visualType": "tableEx",
    "query": {
      "queryState": {
        "Values": {
          "projections": "{{Columns}}"
        }
      }
    },
    "objects": {
      "values": [
        {
          "properties": {
            "fontFamily": {
              "expr": {
                "Literal": {
                  "Value": "'{{FontFamily}}'"
                }
              }
            },
            "fontSize": {
              "expr": {
                "Literal": {
                  "Value": "{{FontSize}}"
                }
              }
            }
          }
        }
      ],
      "columnHeaders": [
        {
          "properties": {
            "fontFamily": {
              "expr": {
                "Literal": {
                  "Value": "'{{HeaderFontFamily}}'"
                }
              }
            },
            "fontSize": {
              "expr": {
                "Literal": {
                  "Value": "{{HeaderFontSize}}"
                }
              }
            }
          }
        }
      ],
      "total": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'{{Title}}'"
                }
              }
            }
          }
        }
      ],
      "background": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "transparency": {
              "expr": {
                "Literal": {
                  "Value": "0D"
                }
              }
            }
          }
        }
      ],
      "border": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ],
      "dropShadow": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ],
      "lockAspect": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ],
      "general": [
        {
          "properties": {
            "keepLayerOrder": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  },
  "filterConfig": {
    "filters": [
      {
        "name": "{{FilterGuid}}",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "{{TableName}}"
              }
            },
            "Property": "{{ColumnName}}"
          }
        },
        "type": "Advanced",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "{{FilterSourceAlias}}",
              "Entity": "{{TableName}}",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "And": {
                  "Left": {
                    "Comparison": {
                      "ComparisonKind": 2,
                      "Left": {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "{{FilterSourceAlias}}"
                            }
                          },
                          "Property": "{{ColumnName}}"
                        }
                      },
                      "Right": {
                        "DateSpan": {
                          "Expression": {
                            "Literal": {
                              "Value": "{{DateStart}}"
                            }
                          },
                          "TimeUnit": 5
                        }
                      }
                    }
                  },
                  "Right": {
                    "Comparison": {
                      "ComparisonKind": 4,
                      "Left": {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "{{FilterSourceAlias}}"
                            }
                          },
                          "Property": "{{ColumnName}}"
                        }
                      },
                      "Right": {
                        "DateSpan": {
                          "Expression": {
                            "Literal": {
                              "Value": "{{DateEnd}}"
                            }
                          },
                          "TimeUnit": 5
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      },
      {
        "name": "{{FilterGuidTopN}}",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "{{CategoryTable}}"
              }
            },
            "Property": "{{CategoryColumn}}"
          }
        },
        "type": "TopN",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "subquery",
              "Expression": {
                "Subquery": {
                  "Query": {
                    "Version": 2,
                    "From": [
                      {
                        "Name": "d1",
                        "Entity": "{{CategoryTable}}",
                        "Type": 0
                      },
                      {
                        "Name": "f",
                        "Entity": "{{MeasureTable}}",
                        "Type": 0
                      }
                    ],
                    "Select": [
                      {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "d1"
                            }
                          },
                          "Property": "{{CategoryColumn}}"
                        },
                        "Name": "field"
                      }
                    ],
                    "OrderBy": [
                      {
                        "Direction": "{{TopNDirection}}",
                        "Expression": {
                          "Measure": {
                            "Expression": {
                              "SourceRef": {
                                "Source": "f"
                              }
                            },
                            "Property": "{{MeasureName}}"
                          }
                        }
                      }
                    ],
                    "Top": "{{TopNValue}}"
                  }
                }
              },
              "Type": 2
            },
            {
              "Name": "d1",
              "Entity": "{{CategoryTable}}",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "In": {
                  "Expressions": [
                    {
                      "Column": {
                        "Expression": {
                          "SourceRef": {
                            "Source": "d1"
                          }
                        },
                        "Property": "{{CategoryColumn}}"
                      }
                    }
                  ],
                  "Table": {
                    "SourceRef": {
                      "Source": "subquery"
                    }
                  }
                }
              }
            }
          ]
        }
      }
    ]
  }
}
