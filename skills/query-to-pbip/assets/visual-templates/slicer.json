{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "{{VisualName}}",
  "position": {
    "x": 0,
    "y": 0,
    "z": 4000,
    "height": 110,
    "width": 110,
    "tabOrder": 4000
  },
  "visual": {
    "visualType": "slicer",
    "query": {
      "queryState": {
        "Values": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "{{SlicerTable}}"
                    }
                  },
                  "Property": "{{SlicerColumn}}"
                }
              },
              "queryRef": "{{SlicerTable}}.{{SlicerColumn}}",
              "nativeQueryRef": "{{SlicerColumn}}",
              "active": true
            }
          ]
        }
      }
    },
    "objects": {
      "data": [
        {
          "properties": {
            "numericEnd": {
              "expr": {
                "Literal": {
                  "Value": "{{NumericEndValue}}"
                }
              }
            },
            "mode": {
              "expr": {
                "Literal": {
                  "Value": "'Dropdown'"
                }
              }
            },
            "canSelectAll": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ],
      "general": [
        {
          "properties": {
            "orientation": {
              "expr": {
                "Literal": {
                  "Value": "1D"
                }
              }
            }
          }
        }
      ],
      "selection": [
        {
          "properties": {
            "singleSelect": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'{{Title}}'"
                }
              }
            }
          }
        }
      ],
      "background": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "transparency": {
              "expr": {
                "Literal": {
                  "Value": "0D"
                }
              }
            }
          }
        }
      ],
      "border": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ],
      "dropShadow": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ],
      "lockAspect": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ],
      "general": [
        {
          "properties": {
            "keepLayerOrder": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  },
  "filterConfig": {
    "filters": [
      {
        "name": "{{FilterGuid}}",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "{{SlicerTable}}"
              }
            },
            "Property": "{{SlicerColumn}}"
          }
        },
        "type": "Advanced",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "{{FilterSourceAlias}}",
              "Entity": "{{SlicerTable}}",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "And": {
                  "Left": {
                    "Comparison": {
                      "ComparisonKind": 2,
                      "Left": {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "{{FilterSourceAlias}}"
                            }
                          },
                          "Property": "{{SlicerColumn}}"
                        }
                      },
                      "Right": {
                        "DateSpan": {
                          "Expression": {
                            "Literal": {
                              "Value": "{{DateStart}}"
                            }
                          },
                          "TimeUnit": 5
                        }
                      }
                    }
                  },
                  "Right": {
                    "Comparison": {
                      "ComparisonKind": 4,
                      "Left": {
                        "Column": {
                          "Expression": {
                            "SourceRef": {
                              "Source": "{{FilterSourceAlias}}"
                            }
                          },
                          "Property": "{{SlicerColumn}}"
                        }
                      },
                      "Right": {
                        "DateSpan": {
                          "Expression": {
                            "Literal": {
                              "Value": "{{DateEnd}}"
                            }
                          },
                          "TimeUnit": 5
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      }
    ]
  }
}
