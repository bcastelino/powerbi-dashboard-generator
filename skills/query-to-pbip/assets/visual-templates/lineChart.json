        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "{{FilterSourceAlias1}}",
              "Entity": "{{CategoryTable1}}",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "Comparison": {
                  "ComparisonKind": 3,
                  "Left": {
                    "Column": {
                      "Expression": {
                        "SourceRef": {
                          "Source": "{{FilterSourceAlias1}}"
                        }
                      },
                      "Property": "{{CategoryColumn1}}"
                    }
                  },
                  "Right": {
                    "Literal": {
                      "Value": "{{FilterValue1}}"
